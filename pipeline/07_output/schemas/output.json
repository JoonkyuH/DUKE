{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionRecord",
  "description": "Layer 7 output — the completed decision record written to data/journal/",
  "type": "object",
  "required": [
    "ticker",
    "date",
    "decided_at",
    "analyst_recommendation",
    "action",
    "conviction_1_to_10"
  ],
  "properties": {
    "ticker":       { "type": "string" },
    "company_name": { "type": "string" },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Decision date YYYY-MM-DD — used in journal filename"
    },
    "decided_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp"
    },

    "synthesis_id":    { "type": ["string", "null"] },
    "debate_reference": { "type": ["string", "null"] },

    "analyst_recommendation": {
      "type": "string",
      "enum": ["strong_conviction_enter", "moderate_conviction_enter", "watch", "pass", "blocked"]
    },
    "final_evidence_score":    { "type": ["number", "null"] },
    "final_confidence_score":  { "type": ["number", "null"] },
    "debate_outcome":          { "type": ["string", "null"] },
    "overall_risk_assessment": { "type": ["string", "null"] },
    "philosophy_fit":          { "type": ["string", "null"] },
    "investment_archetype":    { "type": ["string", "null"] },
    "executive_summary":       { "type": ["string", "null"] },
    "what_would_change_this":  { "type": ["string", "null"] },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "monitoring_priorities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority":    { "type": "integer" },
          "description": { "type": "string" },
          "source":      { "type": "string" },
          "frequency":   { "type": "string" }
        }
      }
    },
    "learning_hooks": {
      "type": "array",
      "description": "Bull + bear learning hooks persisted for 90/180/365-day outcome tracking",
      "items": {}
    },

    "action": {
      "type": "string",
      "enum": ["enter", "watch", "pass", "override"],
      "description": "What the investor actually decided to do"
    },
    "position_size_pct": {
      "type": ["number", "null"],
      "description": "Position size as % of portfolio (null if action is watch/pass)"
    },
    "conviction_1_to_10": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "override_recommendation": {
      "type": ["string", "null"],
      "description": "Investor's actual decision when overriding the analyst"
    },
    "override_reason": {
      "type": ["string", "null"],
      "description": "Required when action is override"
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
