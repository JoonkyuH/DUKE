{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 01 Screening Output",
  "description": "Output written by run_screening.py to data/screening/shortlist_{date}.json",
  "type": "object",
  "required": ["generated_at", "universe_size", "shortlist_size", "regime", "tickers"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when the screening was run"
    },
    "universe_size": {
      "type": "integer",
      "description": "Total number of tickers evaluated"
    },
    "shortlist_size": {
      "type": "integer",
      "description": "Number of tickers that passed the regime threshold"
    },
    "regime": {
      "type": "string",
      "description": "Market regime detected by regime_classifier (e.g. RISK_ON_MOMENTUM)"
    },
    "tickers": {
      "type": "array",
      "description": "Shortlist entries — tickers that passed the regime composite threshold",
      "items": {
        "type": "object",
        "required": ["ticker", "archetype", "composite_score", "conviction", "reason_codes", "flags", "rank"],
        "additionalProperties": true,
        "properties": {
          "ticker": { "type": "string" },
          "archetype": {
            "type": "string",
            "description": "Investment archetype assigned by screener (e.g. long_term_compounder)"
          },
          "composite_score": {
            "type": "number",
            "description": "Regime-weighted composite signal score (0–100)"
          },
          "conviction": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"],
            "description": "Conviction level derived from composite_score"
          },
          "reason_codes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Short codes explaining why the ticker was shortlisted"
          },
          "flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Investigation flags for Stage 02 (e.g. earnings_proximity)"
          },
          "rank": {
            "type": "integer",
            "description": "Rank within the shortlist (1 = highest composite score)"
          },
          "signal_scores": {
            "type": ["object", "null"],
            "description": "Individual signal scores used to compute the composite. Null values indicate missing data.",
            "properties": {
              "business_quality":      { "type": ["number", "null"] },
              "valuation_vs_growth":   { "type": ["number", "null"] },
              "historical_discount":   { "type": ["number", "null"] },
              "earnings_quality":      { "type": ["number", "null"] },
              "entry_vs_fundamentals": { "type": ["number", "null"] },
              "binary_event_risk":     { "type": ["number", "null"] }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
