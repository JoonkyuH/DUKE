{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SynthesisOutput",
  "description": "Layer 6 output — Chief Analyst brief and synthesis metadata",
  "type": "object",
  "required": [
    "synthesis_id",
    "debate_reference",
    "ticker",
    "company_name",
    "synthesized_at",
    "chief_analyst_brief",
    "debate_evidence_score",
    "debate_confidence_score",
    "debate_outcome",
    "overall_risk_assessment",
    "ready_for_chief_analyst",
    "blocking_issues"
  ],
  "properties": {
    "synthesis_id": {
      "type": "string",
      "pattern": "^SYN-[A-Z]+-\\d{8}-\\d{4}-[A-Z0-9]{4}$",
      "description": "SYN-{TICKER}-{YYYYMMDD}-{HHMM}-{RAND4}"
    },
    "debate_reference": {
      "type": "string",
      "description": "DebateRecord.debate_id this synthesis was built from"
    },
    "ticker": { "type": "string" },
    "company_name": { "type": "string" },
    "synthesized_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp"
    },
    "chief_analyst_brief": {
      "type": "object",
      "description": "Full structured context fed to the Chief Analyst agent",
      "required": ["role", "instruction", "ticker", "scores", "debate_outcome", "bull_position", "bear_position", "contentions", "risk_assessment", "output_format"],
      "properties": {
        "role": { "type": "string", "const": "chief_analyst" },
        "instruction": { "type": "string" },
        "ticker": { "type": "string" },
        "company_name": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "base_evidence_score":     { "type": ["number", "null"] },
            "base_confidence_score":   { "type": ["number", "null"] },
            "debate_evidence_score":   { "type": ["number", "null"] },
            "debate_confidence_score": { "type": ["number", "null"] },
            "original_conviction":     { "type": ["string", "null"] },
            "original_recommendation": { "type": ["string", "null"] }
          }
        },
        "debate_outcome": { "type": ["string", "null"] },
        "bull_position": { "type": "object" },
        "bear_position": { "type": "object" },
        "contentions": {
          "type": "array",
          "description": "Sorted CRITICAL first",
          "items": { "type": "object" }
        },
        "risk_assessment": { "type": "object" },
        "output_format": {
          "type": "object",
          "description": "Schema template the Chief Analyst must conform to"
        }
      }
    },
    "debate_evidence_score": { "type": "number" },
    "debate_confidence_score": { "type": "number" },
    "debate_outcome": { "type": "string" },
    "overall_risk_assessment": {
      "type": "string",
      "enum": ["adequate", "needs_attention", "inadequate"]
    },
    "ready_for_chief_analyst": { "type": "boolean" },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "contention_count":     { "type": "integer" },
        "critical_contentions": { "type": "integer" },
        "material_contentions": { "type": "integer" },
        "raised_risks_count":   { "type": "integer" }
      }
    },
    "chief_analyst_output": {
      "type": "object",
      "description": "Chief Analyst LLM output. Schema documented in chief_analyst.md."
    },
    "computed_entry": {
      "type": "object",
      "description": "Python-computed entry-price band from entry_price_calculator.compute_entry_price(). The Chief Analyst reads these fields but does not recompute them; they are written directly to the journal by Stage 07.",
      "properties": {
        "case_label":        { "type": "string", "enum": ["IN_BAND", "ABOVE_BAND", "BELOW_BEAR", "INVERTED", "DEGENERATE"] },
        "entry_price":       { "type": ["number", "null"] },
        "entry_range":       { "type": ["object", "null"], "properties": { "low": {"type":"number"}, "high": {"type":"number"} } },
        "target_2to1_price": { "type": ["number", "null"] },
        "ratio_at_current":  { "type": ["number", "null"] },
        "archetype":         { "type": "string" },
        "archetype_min_rr":  { "type": ["number", "null"] },
        "price_gate_passed": { "type": ["boolean", "null"] },
        "rationale":         { "type": "string" },
        "current_price_used": { "type": ["number", "null"] }
      }
    },
    "risk_assessment": {
      "type": "object",
      "description": "Risk Officer output, passed through for Stage 07."
    },
    "learning_hooks": {
      "type": "array",
      "description": "Collected bull + bear learning hooks for 90/180/365-day outcome tracking."
    }
  },
  "additionalProperties": false
}
