{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "screening_output",
  "title": "Screening Output",
  "description": "Full output of the initial screening pass. Contains market regime classification and a ranked shortlist of tickers for Layer 2 deep research.",
  "type": "object",
  "required": ["screening_id", "timestamp", "market_regime", "shortlist"],
  "properties": {

    "screening_id": {
      "type": "string",
      "description": "Unique ID for this screening run (e.g. SCR-20250514-0930-A3F1)"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp of screening completion"
    },

    "market_regime": {
      "type": "string",
      "enum": [
        "risk_on_momentum",
        "risk_off_defensive",
        "liquidity_expansion",
        "liquidity_contraction",
        "earnings_volatility",
        "macro_uncertainty"
      ],
      "description": "Classified market regime at time of screening"
    },

    "regime_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the regime classification (0–1)"
    },

    "universe_size": {
      "type": "integer",
      "description": "Total number of tickers evaluated in this pass"
    },

    "threshold_applied": {
      "type": "number",
      "description": "Minimum composite score required to enter the shortlist. Regime-dependent. Fallback = 45."
    },

    "shortlist": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "description": "Ranked list of tickers that passed screening. Priority 1 = highest score.",
      "items": {
        "type": "object",
        "required": ["ticker", "composite_score", "signal_scores", "reason_codes", "priority"],
        "properties": {

          "ticker": { "type": "string" },

          "composite_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Raw weighted composite of all six signal scores"
          },

          "regime_adjusted_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Composite score after regime weight application (V1: same as composite)"
          },

          "signal_scores": {
            "type": "object",
            "description": "Individual 0–100 scores for each signal",
            "required": ["momentum", "relative_strength", "volume_anomaly", "sector_leadership", "news_velocity", "earnings_proximity"],
            "properties": {
              "momentum":           { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "relative_strength":  { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "volume_anomaly":     { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "sector_leadership":  { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "news_velocity":      { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "earnings_proximity": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
            }
          },

          "signal_weights_applied": {
            "type": "object",
            "description": "The regime-specific weights used for this scoring run",
            "properties": {
              "momentum":           { "type": "number" },
              "relative_strength":  { "type": "number" },
              "volume_anomaly":     { "type": "number" },
              "sector_leadership":  { "type": "number" },
              "news_velocity":      { "type": "number" },
              "earnings_proximity": { "type": "number" }
            }
          },

          "regime_at_screening": {
            "type": "string",
            "description": "Regime active at the time this ticker was scored"
          },

          "reason_codes": {
            "type": "array",
            "description": "Codes explaining why this ticker passed screening",
            "items": {
              "type": "string",
              "enum": [
                "MOMENTUM_BREAKOUT",
                "MOMENTUM_STRONG",
                "RS_MARKET_LEADER",
                "RS_SECTOR_TOP_QUARTILE",
                "VOLUME_SURGE",
                "VOLUME_ABOVE_AVERAGE",
                "SECTOR_LEADER",
                "NEWS_ACCELERATION",
                "EARNINGS_CATALYST_IMMINENT",
                "EARNINGS_CATALYST_WINDOW",
                "MULTI_SIGNAL_CONFLUENCE"
              ]
            }
          },

          "flags": {
            "type": "array",
            "description": "Concerns for Layer 2 to investigate. A flag does not disqualify a ticker.",
            "items": {
              "type": "string",
              "enum": [
                "FLAG_OVERBOUGHT_RSI",
                "FLAG_HIGH_VOL_DOWN_DAY",
                "FLAG_NEGATIVE_NEWS",
                "FLAG_WEAK_SECTOR",
                "FLAG_LOW_SOURCE_QUALITY",
                "FLAG_EARNINGS_GAP_RISK"
              ]
            }
          },

          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "Rank within shortlist. 1 = highest composite score."
          }
        }
      }
    },

    "shortlist_count": {
      "type": "integer",
      "description": "Number of tickers in the shortlist"
    },

    "metadata": {
      "type": "object",
      "properties": {
        "regime_description":      { "type": "string" },
        "regime_weights":          { "type": "object" },
        "fallback_threshold_used": { "type": "boolean" },
        "screening_duration_ms":   { "type": "integer" },
        "warnings":                { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
